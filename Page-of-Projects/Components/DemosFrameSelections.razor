@page "/demos"
<h2>Demos</h2>

<FrameSelectionItems FrameSelections="@DemosSelections" SelectedFrame="@SelectedFrame" OnSelected="@OnSelected" />

@code {
    [Parameter]
    public EventCallback<FrameSelectionOption> OnSelected { get; set; }
    
    [Parameter]
    public required List<FrameSelectionOption> DemosSelections { get; set; }

    [Parameter]
    public FrameSelectionOption? SelectedFrame { get; set; } = null;
}
