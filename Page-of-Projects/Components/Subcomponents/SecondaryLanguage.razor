@using ProjectsPage.Models
@namespace ProjectsPage.Components.Subcomponents

@if (SelectedWebsite.SelectionDetails.SecondaryLanguage is not null && SelectedWebsite.SelectionDetails.SecondaryLanguage.Count > 0)
{

    <p class="mb0" data-visibility="@(IsHoverElement ? "no-scan" : "none")">
        @if(IsHoverElement)
        {
            <strong data-visibility="@(IsHoverElement ? "no-scan" : "none")">Secondary Language(s): </strong>
        
        }
        else {
            <span data-visibility="@(IsHoverElement ? "no-scan" : "none")">Secondary Language(s): </span>
        }
    

        @for (var i = 0; i < SelectedWebsite.SelectionDetails.SecondaryLanguage.Count; i++)
        {
            @if (SelectedWebsite.SelectionDetails.SecondaryLanguage.Count - 1 == i)
            {
                @SelectedWebsite.SelectionDetails.SecondaryLanguage[i]
                break;
            }
            else
            {
                @SelectedWebsite.SelectionDetails.SecondaryLanguage[i]
                <span data-visibility="@(IsHoverElement ? "no-scan" : "none")">, </span>
            }
        }
    </p>
    @if (!String.IsNullOrWhiteSpace(SelectedWebsite.SelectionDetails.Framework))
    {
        <p class="mb0" data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">
        @if (IsHoverElement)
        {
            <strong data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">Framework: </strong>
        }
        else
        {
            <span data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">Framework: </span>
        }
        @SelectedWebsite.SelectionDetails.Framework
         </p>
    }
    @if (SelectedWebsite.SelectionDetails.Database is { HasDatabase: true })
    {
        <p class="mb0" data-visibility="@(IsHoverElement ? "no-scan" : "none")">
            @if (IsHoverElement)
            {
                <strong data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">Has Database: </strong>
            }
            else
            {
                <span data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">Has Database: </span>
            }
             @SelectedWebsite.SelectionDetails.Database.HasDatabase
        </p>
    }
    @if (SelectedWebsite.SelectionDetails.HostingDetails is { IsCloud: true })
    {
        <p class="mb0" data-visibility="@(IsHoverElement ? "no-scan" : "none")">
            @if (IsHoverElement)
            {
                <strong data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">Cloud Hosted: </strong>
            }
            else
            {
                <span data-visibility="@(IsHoverElement ? "no-scan" : "no-replace")">Cloud Hosted: </span>
            }
            @SelectedWebsite.SelectionDetails.HostingDetails.IsCloud
        </p>
    }
}

@code {
    [Parameter] public required FrameSelectionOption SelectedWebsite { get; set; }
    [Parameter] public required bool IsHoverElement { get; set; }
}
