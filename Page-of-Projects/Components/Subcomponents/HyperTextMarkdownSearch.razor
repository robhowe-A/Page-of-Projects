@using System.Diagnostics.Tracing
@inject IJSRuntime JS

<div id="domSearch">
    <search>
        <a>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
            </svg>
        </a>
        <input id="search"/>
    </search>
    <output id="domSearchOutput">
    @if (Nodes.Count > 0)
    {
        foreach (var node in @Nodes)
        {
            <strong>node</strong>
        }
    }
    </output>
</div>

@code {
    private int _count;
    private DotNetObjectReference<HyperTextMarkdownSearch>? objRef;
    [Parameter] public List<object> Nodes { get; set; } = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("main.input", objRef);
        }
    }

    private int _dialogIndexClicked { get; set; }
    [Parameter] public EventCallback<int> OnReceiveSearchFindingNodeClicked { get; set; } 
    [Parameter] public EventCallback<int> OnCount { get; set; }
    [JSInvokable]
    public Task ReceiveSearchFindingNodeClicked(int dialogIndexClicked)
    {
        _dialogIndexClicked = dialogIndexClicked;
        WriteLine($"SearchFindingDialogIndexClicked: {dialogIndexClicked}");
        StateHasChanged();
        OnReceiveSearchFindingNodeClicked.InvokeAsync(dialogIndexClicked);
        
        return Task.CompletedTask;
    }


    [JSInvokable]
    public Task ReceiveSearchFindingsCount(int value)
    {
        _count = value;
        OnCount.InvokeAsync(_count);
        StateHasChanged();
        return Task.CompletedTask;
    }

    public ValueTask DisposeAsync()
    {
        objRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}
