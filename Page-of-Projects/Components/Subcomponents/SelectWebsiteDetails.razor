@using ProjectsPage.Models
@namespace ProjectsPage.Components.Subcomponents

@if (ShowDetails)
{
    WriteLine($"SelectDetails__{SelectedWebsite}Title:{SelectedWebsite.Title}");
    <aside class="page-view-detail
        @( ShowDetails ? "show-details" : "" )" data-panel-index="0">
        <SelectedWebsiteDetails 
        SelectedWebsite="@SelectedWebsite" 
        ShowDetails="ShowDetails"
        DialogIndex="@StartingNumber"
        OnAfterNavigateClosePanel="@OnAfterNavigateClosePanel" />
    <button @onclick="() => OnCloseClicked.InvokeAsync(false)" class="mb1 details-panel-toggle disabled secondary">Close</button>
</aside>
}

@code {
    [Parameter]
    public required FrameSelectionOption SelectedWebsite { get; set; }

    [Parameter]
    public bool ShowDetails { get; set; }

    [Parameter]
    public EventCallback<bool> OnCloseClicked { get; set; }
    
    [Parameter]
    public EventCallback<bool> OnAfterNavigateClosePanel { get; set; }

    [Parameter]
    public int StartingNumber { get; set; }
}
