@using ProjectsPage.Models
@namespace ProjectsPage.Components.Primary

<PageTitle>@_centralizedTitleStr</PageTitle>

@if (string.Equals(_centralizedPageUrl, string.Empty))
{

    <iframe id="SFNA" class="page-view" src="@Url"></iframe>

}
else
{
    @if (!string.IsNullOrEmpty(DocsPathUri))
    {
        <iframe id="SFNA" class="page-view" src="@(_centralizedPageUrl+DocsPathUri)"></iframe>
    }
    else
    {
        <iframe class="page-view" src="@_centralizedPageUrl"></iframe>
    }
}

@code {
    [Parameter]
    public string Url { get; set; } = string.Empty;

    private static string TitleFrom { get; set; }
    [Parameter]
    public string Title
    {
        get;
        set 
        { 
            TitleFrom = value;
            field = value;
        }
    }

    private static bool IsWebsiteFrom { get; set; }

    [Parameter]
    public bool? IsWebsite
    {
        get;
        set
        {
            IsWebsiteFrom = (bool)value;
            field = value;
        }
    }

    [Parameter]
    public string? DocsPathUri { get; set; }

    [Parameter] 
    public EventCallback<FrameSelectionOption?> SelectedWebsiteChanged { get; set; }
    
    private FrameSelectionOption? SelectedWebsite { get; set; } = IsWebsiteFrom ? FrameSelectionData.WebsiteSelections.FirstOrDefault(x => x.Title == TitleFrom) : FrameSelectionData.DemoSelections.FirstOrDefault(x => x.Title == TitleFrom);

    private string _centralizedPageUrl = string.Empty;
    private string _centralizedTitleStr = string.Empty;

    protected override void OnInitialized()
    {
        GetPageOptionDetail();
        if (SelectedWebsite != null)
        {
            SelectedWebsiteChanged.InvokeAsync(SelectedWebsite);
        }
    }

    private void GetPageOptionDetail()
    {
        if(IsWebsite == null)
            throw new InvalidDataException();

        FrameSelectionOption spaceFlightWeb;
        try
        {
            var websitesOptionsData = FrameSelectionData.WebsiteSelections
                .Concat(FrameSelectionData.DemoSelections);

            spaceFlightWeb = websitesOptionsData
                .FirstOrDefault(x =>
                {
                    return x.Title == Title;
                })! ?? throw new InvalidDataException();
        }
        catch (Exception e)
        {
            Console.Write("An exception occurred due to invalid data: ");
            Console.Write($"{e.Message}\n{e.StackTrace}\n");
            Console.Write($"Continuing to display the page with URL {Url}.");
            return;
        }

        _centralizedPageUrl = spaceFlightWeb.ExternalHref;
        _centralizedTitleStr = spaceFlightWeb.Title;
    }

}
