@using ProjectsPage.Components.Subcomponents
@using ProjectsPage.Models

@namespace ProjectPages.Components.Primary
@if(DeploymentAs == "ALL"){
    @if (!IsSortedNewest)
    {
        <button class="details-panel-sort" @onclick="sortAllDateEnd">Newest</button>
    }
    @if (IsSortedNewest)
    {
        <button class="details-panel-sort" @onclick="sortAllDateStart">Started</button>
    }
    @if (!IsSortedAZ)
    {
        <button class="details-panel-sort" @onclick="sortAllAZ">A-Z</button>
    }
    @if (IsSortedAZ)
    {
        <button class="details-panel-sort" @onclick="sortAllZA">Z-A</button>
    }
}
<ul>
    @foreach (var frame in @FrameSelections.ToArray())
    {
        <li>
            <div class="page-view-selection @(SelectedFrame?.Title == frame.Title ? "displaying" : "")" @onclick="() => OnSelectedOnClick(frame)">
                @*PROJECTS*@<img src="@frame.ImageUrl" alt="@frame.ImageAltText"/>
                <div class="page-view-selection-text">
                    <a class="page-view-link" href="@frame.Href"
                       title="@frame.Title">@frame.InnerText</a>
                    @*PROJECTS*@<button class="details-panel-toggle @(SelectedFrame != null ? "disabled" : "disabled greyed")" @onclick:stopPropagation="true" @onclick="() => ToggleDetailsOnClick(frame)">Details</button>
                    @*PROJECTS*@
                    <a class="information-panel-toggle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                            <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                        </svg>
                        <div class="information-panel" data-visibility="no-scan">
                            <h3 data-visibility="no-scan">@frame.Title</h3>
                            <p data-visibility="no-scan"><strong data-visibility="no-scan">Language:</strong> @frame.SelectionDetails.ProgrammingLanguage</p>
                            <SecondaryLanguage SelectedWebsite="@frame" IsHoverElement="true"/>
                            @if (!String.IsNullOrWhiteSpace(@frame.SelectionDetails.Framework))
                            {
                                <p data-visibility="no-scan"><strong data-visibility="no-scan">Framework:</strong> @frame.SelectionDetails.Framework</p>
                            }
                            @* <p><strong>Database:</strong> @frame.SelectionDetails.Database</p> *@
                            @* <p><strong>Deployment:</strong> @frame.Deployment</p> *@
                            @* <p><strong>Hosting:</strong> @frame.Hosting</p> *@
                        </div>
                    </a>
                </div>
            </div>
            <SelectedWebsiteDetails
                SelectedWebsite="@frame"
                ShowDetails="@false"
                DialogIndex="@StartingNumber"/>
            @{
                MaintainDialogIndex.TryAdd(frame.Title, StartingNumber);
                DialogIndexData.TryAdd(frame.Title, frame);
                StartingNumber++;
                frame.SelectionDetails.Deployment = DeploymentAs ?? "N/A";
            }

        </li>

    }
</ul>

@code {

    public async Task sortAllDateStart()
    {
        SortOrderSelected = SortOrder.OLDEST;
        IsSortedNewest = false;
        await OnResortedListSelected.InvokeAsync((SortOrderSelected, DeploymentAs));
    }
    public async Task sortAllDateEnd()
    {
        SortOrderSelected = SortOrder.NEWEST;
        IsSortedNewest = true;
        await OnResortedListSelected.InvokeAsync((SortOrderSelected, DeploymentAs));
    }
    public async Task sortAllAZ()
    {
        SortOrderSelected = SortOrder.AZ;
        IsSortedAZ = true;
        await OnResortedListSelected.InvokeAsync((SortOrderSelected, DeploymentAs));
    }
    public async Task sortAllZA()
    {
        SortOrderSelected = SortOrder.ZA;
        IsSortedAZ = false;
        await OnResortedListSelected.InvokeAsync((SortOrderSelected, DeploymentAs));
    }

    private bool IsSortedAZ = default;
    private bool IsSortedNewest = true; //sort order starts as NEWEST
    
    private static Dictionary<string, int> MaintainDialogIndex { get; } = new();

    private static Dictionary<string, FrameSelectionOption> DialogIndexData = new();

    [Parameter] public string DeploymentAs { get; set; }
    
    [Parameter]
    public required List<FrameSelectionOption> FrameSelections { get; set; }

    [Parameter]
    public FrameSelectionOption? SelectedFrame { get; set; } = null;

    [Parameter]
    public EventCallback<FrameSelectionOption> OnSelected { get; set; }
    
    [Parameter]
    public EventCallback<(SortOrder, string)> OnResortedListSelected { get; set; }

    private SortOrder SortOrderSelected { get; set; } = SortOrder.NEWEST;

    //[Parameter]
    //public EventCallback<(bool, FrameSelectionOption, int)> OnSelectionChange { get; set; }
[Parameter]public EventCallback<int> OnSelectionChange { get; set; }

    [Parameter]
    public bool? SetDetail { get; set; }

    public static bool IsDetailsShowing { get; set; } = true;
    private bool IsMouseOver = false;
    private Dictionary<string, string> ItemsInfoPanelAreOpen = new();

    public class DialogIndexDataFetch
    {
        public static FrameSelectionOption SearchFindingNodeClicked_FindFrameOptionToOpen(int dialogIndexToOpen)
        {
            DialogIndexDataFetch dialogIndexDataFetch = new DialogIndexDataFetch();
            return dialogIndexDataFetch.GetFrameOptionByIndex(DialogIndexData,MaintainDialogIndex,dialogIndexToOpen);
        }

        public static int GetFrameOptionIndexByFrameSelectionOption(FrameSelectionOption frame)
        {
            DialogIndexDataFetch dialogIndexDataFetch = new DialogIndexDataFetch();
            return dialogIndexDataFetch.GetDialogIndexByFrameSelectionOption(MaintainDialogIndex,frame);
        }

        private int GetDialogIndexByFrameSelectionOption(Dictionary<string, int> maintainDialogIndex, FrameSelectionOption frame)
        {
            var frameDialogIndex = maintainDialogIndex.FirstOrDefault(x => x.Key == frame.Title);
            return frameDialogIndex.Value;
        }
        
        private FrameSelectionOption GetFrameOptionByIndex(Dictionary<string, FrameSelectionOption> dialogIndexData, Dictionary<string, int> maintainDialogIndex, int dialogIndexToOpen)
        {
            var dialogIndex = maintainDialogIndex.FirstOrDefault(x => x.Value == dialogIndexToOpen);
            return dialogIndexData[dialogIndex.Key];
        }
    }


    private void ToggleDetailsOnClick(FrameSelectionOption selectedFrame)
    {
        //NEEDED? ... ready for toggle button
        if (SetDetail != null && IsDetailsShowing == SetDetail)
        {
            //OnSelectionChange.InvokeAsync((false, selectedFrame, MaintainDialogIndex[selectedFrame.Title]));
            OnSelectionChange.InvokeAsync(MaintainDialogIndex[selectedFrame.Title]);
        }
        else {
            //OnSelectionChange.InvokeAsync((true, selectedFrame, MaintainDialogIndex[selectedFrame.Title]));
            OnSelectionChange.InvokeAsync(MaintainDialogIndex[selectedFrame.Title]);
        }
    }

    private void OnSelectedOnClick(FrameSelectionOption frame)
    {
        OnSelected.InvokeAsync(frame);
    }

    private void OnMouseOverInfoToggle()
    {
        IsMouseOver = true;
    }

    [Parameter] public int StartingNumber { get; set; }
}
