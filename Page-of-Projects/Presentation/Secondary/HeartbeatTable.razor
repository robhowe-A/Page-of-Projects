@using System.Collections.Immutable
@using ProjectsPage.Domain
@namespace ProjectsPage.Components.Secondary

<div>
    <button @onclick="@(()=>ToggleViewSummary())">Table</button>
    <button @onclick="ToggleViewSummary">Summary</button>
</div>

<table>
@if (IsViewSummary)
{
    var dateCursor = DateTime.Now;
    var recordComparison = Comparer<HeartbeatData>.Create((x, y) => y.Id.CompareTo(x.Id));
    var allHeartbeats = new SortedSet<HeartbeatData>(Heartbeats.ToImmutableList(), recordComparison);
    const string dateMeasure = "YEAR";
    const string dateMeasureMonth = "MONTH";
    const string dateMeasureDay = "DAY";

    static (Predicate<HeartbeatData>, SortedSet<HeartbeatData>) GetLoopDataSet(
            string dateMeasure, IEnumerable<HeartbeatData> heartbeats,
            DateTime date, Comparer<HeartbeatData> recordComparison)
    {
        var timeValue = dateMeasure switch
                    {
                           "YEAR" => date.Year,
                           "MONTH" => date.Month,
                           "DAY" => date.Day,
                           _ => throw new ArgumentException("Invalid date measure")
                    };

        Predicate<HeartbeatData> selection = dateMeasure switch
                    {
                         "YEAR" => i => i.Timestamp.Year == timeValue,
                         "MONTH" => i => i.Timestamp.Month == timeValue,
                         "DAY" => i => i.Timestamp.Day == timeValue,
                         _ => throw new ArgumentException("Invalid date measure")
                    };

        var heartbeatData = heartbeats.ToList();
        var heartbeatsSelection = heartbeatData.Where(selection.Invoke);
        var sortedHeartbeats = new SortedSet<HeartbeatData>(heartbeatsSelection, recordComparison);

        return (selection, sortedHeartbeats);
    }

    <tbody>
    @do
    {
        (Predicate<HeartbeatData> yearSelection, SortedSet<HeartbeatData> yearHeartbeats)
        = GetLoopDataSet(dateMeasure, allHeartbeats, dateCursor, recordComparison);

        var yearKey = $"{dateCursor.Year}";

        <tr>
            <td><button @onclick="() => Toggle(yearKey)">@(IsExpanded(yearKey) ? "−" : "+")</button>
                @dateCursor.Year
            </td>
            <td></td>
            <td></td>
            <td>-</td>
            <td>-</td>
            <td></td>
            <td>-</td>
        </tr>

        do
        {
            (Predicate<HeartbeatData> monthSelection, SortedSet<HeartbeatData> monthHeartbeats)
                = GetLoopDataSet(dateMeasureMonth, yearHeartbeats, dateCursor, recordComparison);

            var monthKey = $"{dateCursor.Year}-{dateCursor.Month}";

            if (IsExpanded(yearKey))
            {
                <tr>
                    <td>
                        <button @onclick="() => Toggle(monthKey)">@(IsExpanded(monthKey) ? "−" : "+")</button>
                        @dateCursor.ToString("MMMM")
                    </td>
                    <td></td>
                    <td></td>
                    <td>-</td>
                    <td>-</td>
                    <td></td>
                    <td>-</td>
                </tr>
            }

            while (monthHeartbeats.Count > 0)
            {
                (Predicate<HeartbeatData> daySelection, SortedSet<HeartbeatData> dayHeartbeats)
                    = GetLoopDataSet(dateMeasureDay, monthHeartbeats, dateCursor, recordComparison);

                var dayKey = $"{dateCursor.Year}-{dateCursor.Month}-{dateCursor.Day}";

                if (IsExpanded(yearKey) && IsExpanded(monthKey))
                {
                    if (IsExpanded(dayKey) == false)
                    {
                        <tr>
                            <td>
                                <button @onclick="() => Toggle(dayKey)">@(IsExpanded(dayKey) ? "−" : "+")</button>
                                @string.Format("{0,12:d, ddd}", dateCursor)
                            </td>
                            <td></td>
                            <td></td>
                            <td>-</td>
                            <td>-</td>
                            <td></td>
                            <td>-</td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>
                                <button @onclick="() => Toggle(dayKey)">@(IsExpanded(dayKey) ? "−" : "+")</button>
                                Id
                            </td>
                            <td>Timestamp</td>
                            <td>Agent</td>
                            <td>Project</td>
                            <td>Domain</td>
                            <td>Relative Url</td>
                            <td>ResponseCode</td>
                        </tr>
                    }
                }

                if (IsExpanded(yearKey) && IsExpanded(monthKey) && IsExpanded(dayKey))
                {
                    @foreach (var beat in dayHeartbeats)
                    {
                        <tr>
                            <td><span>@beat.Id</span></td>
                            <td><span>@beat.Timestamp</span></td>
                            <td>@beat.Agent</td>
                            <td>@beat.Project</td>
                            <td>@beat.Domain</td>
                            <td>@beat.RelativeUrl</td>
                            <td>@beat.ResponseCode</td>
                        </tr>
                    }
                }

                monthHeartbeats.RemoveWhere(daySelection);
                dateCursor = dateCursor.AddDays(-1);
            };

            yearHeartbeats.RemoveWhere(monthSelection);
        } while (yearHeartbeats.Count > 0);

        allHeartbeats.RemoveWhere(yearSelection);
    } while (allHeartbeats.Count > 0);
    </tbody>
}
else {
    <thead>
        <td>Id</td>
        <td>Timestamp</td>
        <td>Agent</td>
        <td>Project</td>
        <td>Domain</td>
        <td>Relative Url</td>
        <td>Response Code</td>
    </thead>
    <tbody>
    @foreach (var beat in Heartbeats)
    {
        <tr>
            <td>@beat.Id</td>
            <td>@beat.Timestamp</td>
            <td>@beat.Agent</td>
            <td>@beat.Project</td>
            <td>@beat.Domain</td>
            <td>@beat.RelativeUrl</td>
            <td>@beat.ResponseCode</td>
        </tr>
    }
    </tbody>
}
</table>

@code {
    [Parameter]
    public required IEnumerable<HeartbeatData> Heartbeats { get; set; }

    private bool IsViewSummary { get; set; } = true;

    private readonly HashSet<string> _expanded = new();

    private bool IsExpanded(string key) => _expanded.Contains(key);

    private void Toggle(string key)
    {
        if (!_expanded.Remove(key))
        {
            _expanded.Add(key);
        }
    }
    private void ToggleViewSummary()
    {
        IsViewSummary = !IsViewSummary;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _expanded.Add(DateTime.Now.Year.ToString());
        _expanded.Add(DateTime.Now.Year + "-" + DateTime.Now.Month);
        _expanded.Add(DateTime.Now.Year + "-" + DateTime.Now.Month + "-" +DateTime.Now.Day);
    }
}
