@page "/status"
@using Microsoft.AspNetCore.Components.Web
@using ProjectsPage.Domain
@namespace ProjectsPage.Components.Primary
@rendermode  Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<PageTitle>roberthowell.dev</PageTitle>
<article>
    <h2>Status</h2>
    <div>
        @foreach (var domain in @_domainOptions)
        {
            <section>
                <hgroup class="domain">
                    <h2>@domain.Tld</h2> 
                </hgroup>
                <table class="subdomain">
                    <tbody>
                    @foreach (var subdomain in domain.Sites)
                    {
                        <tr>
                            <td class="status">@(_statuses.TryGetValue(subdomain.Url, out var status) ? status : "…")</td>
                            <td><a href="@subdomain.Url" rel="noopener" title="@subdomain.Name" target="_blank">@subdomain.Name</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </section>
        }
    </div>
</article>

@code {
    private Dictionary<string, string> _statuses = new();
    private readonly HealthCheck _healthCheck = new();
    private static readonly List<DomainOption> _domainOptions = FrameSelection.DomainOptionsData(Projects.Domains);

    protected override void OnInitialized()
    {
        UrlsToCheck = _healthCheck.GetUrlsToCheck();
    }

    private async Task DoBackgroundWorkAsync()
    {
        // Start checks after first render so the page can show placeholders immediately.
        _statuses = await _healthCheck.RunChecksAsync(async (url, status) =>
        {
            _statuses[url] = status;
            await InvokeAsync(StateHasChanged);
        }, UrlsToCheck);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        //DoBackgroundWorkAsync().GetAwaiter();
        await DoBackgroundWorkAsync();
        
        
        // Trigger a re-render as each result arrives
        // ADD TRIGGER BTN
        

        return;
    }
}
