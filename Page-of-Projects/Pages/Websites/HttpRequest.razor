@page "/websites/httprequest-app"
@using ProjectsPage.Components.Primary
@using ProjectsPage.Models
@namespace ProjectsPage.Components.Pages.Websites

<PageFrame 
    Url="https://www.httprequest.app/"
    Title="Http Request App"
    IsWebsite="true"
    SelectedWebsiteChanged="OnSelectedWebsiteChanged"/>

@if (PageViewingSelected)
{
    <PageViewing PageSelection="SelectedWebsite"/>
}

@code {
    
    [Parameter] public required FrameSelectionOption SelectedWebsite { get; set; }
    private static bool PageViewingSelected { get; set; }
    private void OnSelectedWebsiteChanged(FrameSelectionOption? selectedWebsite)
    {
        SelectedWebsite = selectedWebsite ?? throw new ApplicationException("No website details");
        PageViewingSelected = true;
        WriteLine($"Page loaded project data: " +
                  $"{selectedWebsite.Title} (selectedWebsite = " +
                  $"{selectedWebsite.DocHrefTitles})");
    }
}