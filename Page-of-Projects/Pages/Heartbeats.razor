@page "/heartbeats"
@using ProjectsPage.Components.Secondary
@using ProjectsPage.Domain
@using ProjectsPage.Infrastructure

<article id="Heartbeats-Page">
    <h3>Heartbeats' Requests</h3>

    <HeartbeatTable Heartbeats="@(
        HeartbeatsAll.ConvertAll(i => new HeartbeatData
        {
              Id = i.Id,
              Timestamp = i.RecordTimestamp,
              Agent = i.Agent,
              Project = i.ProjectName,
              Domain = i.Domain,
              RelativeUrl = i.UrlRel,
              ResponseCode = i.ResponseStatus
        }))" />
</article>

@code {
    private readonly ProjectsHeartbeatFetch _projectsHeartbeatFetch = new();

    private List<Heartbeat> HeartbeatsAll => _projectsHeartbeatFetch.ProjectsHeartbeats();
}
